# Copy to .env next to docker-compose.yml and fill in.

# Postgres password used by both the db and api services.
DB_PASSWORD=change-me

# Kitsu public client credentials (see .planing/02-external-apis.md).
# Defaults are Kitsu's documented public OAuth client.
KITSU_CLIENT_ID=dd031b32d2f56c990b1425efe6c42ad847e7fe3ab46bf1299f05ecd856bdb7dd
KITSU_CLIENT_SECRET=54d7307928f63414defd96399fc31ba847961ceaecef3a5fd93144e960c0e151

# stub: accept any non-empty credentials (development / pre-S2).
# real: perform the actual Kitsu OAuth password grant.
KITSU_AUTH_MODE=stub
